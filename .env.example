# Serksi Agent — optional settings
#
# You usually don't need this file. Copy it to `.env` only if you need one of
# the overrides below.
#
#   cp .env.example .env

# ── Network interface ─────────────────────────────────────────────────────────
# Auto-detected by default. Set this only if the host has multiple NICs and the
# agent picks the wrong one. Run `ip link` to list interfaces.
#SERKSI_INTERFACE=ens33

# ── Headless registration ─────────────────────────────────────────────────────
# By default the agent starts unregistered and you register it through the setup
# wizard at https://<host-ip>:5443.
#
# For automated or bulk deployments, set both of these to register on first boot
# and skip the wizard. Find them at portal.serksi.com → Site Settings → Agent Setup.
#SERKSI_SITE_TOKEN=
#SERKSI_SITE_ID=
#SERKSI_SITE_NAME=My Site

# ── Server ────────────────────────────────────────────────────────────────────
# Change only if you self-host the Serksi server.
#SERKSI_API_URL=https://api.serksi.com